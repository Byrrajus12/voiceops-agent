# ── Dynatrace MCP Server ───────────────────────────────────────
# apps.dynatrace.com URL (Platform API — used by the MCP server)
DT_ENVIRONMENT=https://pmn17776.apps.dynatrace.com
DYNATRACE_TENANT=pmn17776.apps.dynatrace.com
DYNATRACE_ENV_ID=pmn17776
# Platform token (dt0s16.*) — needs scopes:
#   storage:problems:read, storage:events:read, storage:logs:read,
#   davis:problems:read, document:read, environment-api:events:write
DYNATRACE_PLATFORM_TOKEN=your_dt_platform_token_here

# ── GitHub ─────────────────────────────────────────────────────
# PAT needs: contents:read, issues:write, actions:write
GITHUB_PAT=your_github_pat_here
GITHUB_REPO=Byrrajus12/voiceops-agent

# ── Google / Gemini ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GCP_PROJECT=sreagnt
CLOUD_RUN_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json
# Optional: override model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ── Services ───────────────────────────────────────────────────
APPROVAL_SERVER_URL=http://localhost:9000
TARGET_SERVICE_NAME=voiceops-target

# ── Target Service ─────────────────────────────────────────────
BROKEN=false
FAILURE_RATE=0.8
