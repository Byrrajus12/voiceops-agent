# ── Dynatrace MCP Gateway ──────────────────────────────────────
# Dynatrace Platform environment (apps.dynatrace.com)
DT_ENVIRONMENT=https://<your-env-id>.apps.dynatrace.com
DYNATRACE_TENANT=<your-env-id>.apps.dynatrace.com
DYNATRACE_ENV_ID=<your-env-id>
# Platform token (dt0s16.*) — needs scopes:
#   mcp-gateway:servers:read, mcp-gateway:servers:invoke,
#   storage:problems:read, storage:events:read, storage:logs:read,
#   davis:problems:read, document:read
DYNATRACE_PLATFORM_TOKEN=dt0s16.your_token_here

# ── GitHub ─────────────────────────────────────────────────────
# PAT needs: repo, actions:write
GITHUB_PAT=github_pat_your_token_here
GITHUB_REPO=your-org/your-repo

# ── Vertex AI (Gemini via Google Cloud) ───────────────────────
GCP_PROJECT=your_gcp_project_id
CLOUD_RUN_REGION=us-central1
GEMINI_MODEL=gemini-3.0-flash
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=global
# For local dev: path to GCP service account key JSON
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json

# ── VAPI (outbound phone calls) ────────────────────────────────
# Get these from app.vapi.ai — use Twilio as the phone number provider
VAPI_API_KEY=your_vapi_api_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_uuid
VAPI_ASSISTANT_ID=your_vapi_assistant_uuid
VAPI_CALLER_NUMBER=+1xxxxxxxxxx
VAPI_WEBHOOK_URL=https://<your-approval-server>/webhook/vapi

# ── Services ───────────────────────────────────────────────────
APPROVAL_SERVER_URL=http://localhost:8080
TARGET_SERVICE_URL=http://localhost:9000

# ── Target Service ─────────────────────────────────────────────
BROKEN=false
# FAILURE_MODE controls what kind of failure to simulate:
#   crash        - HTTP 500 on all requests (AVAILABILITY)
#   slow         - 5-10s random delays (PERFORMANCE)
#   auth_error   - HTTP 401 on session start (ERROR_RATE)
#   db_timeout   - fake DB timeout with stack trace (AVAILABILITY)
#   dependency   - downstream service unavailable (AVAILABILITY)
FAILURE_MODE=crash
