# ── Dynatrace MCP Gateway ──────────────────────────────────────
# Dynatrace Platform environment (apps.dynatrace.com)
DT_ENVIRONMENT=https://<your-env-id>.apps.dynatrace.com
DYNATRACE_TENANT=<your-env-id>.apps.dynatrace.com
DYNATRACE_ENV_ID=<your-env-id>
# Platform token (dt0s16.*) — needs scopes:
#   mcp-gateway:servers:read, mcp-gateway:servers:invoke,
#   storage:problems:read, storage:events:read, storage:logs:read,
#   davis:problems:read, document:read
DYNATRACE_PLATFORM_TOKEN=your_dt_platform_token_here

# ── GitHub ─────────────────────────────────────────────────────
# PAT needs: repo, actions:write
GITHUB_PAT=your_github_pat_here
GITHUB_REPO=your-org/your-repo

# ── Vertex AI (Gemini via Google Cloud) ───────────────────────
GCP_PROJECT=your_gcp_project_id
CLOUD_RUN_REGION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=global
# For local dev: path to GCP service account key JSON
GOOGLE_APPLICATION_CREDENTIALS=./sa-key.json

# ── Services ───────────────────────────────────────────────────
# Approval server URL (deployed or local)
APPROVAL_SERVER_URL=http://localhost:8080
TARGET_SERVICE_URL=http://localhost:8000

# ── Target Service ─────────────────────────────────────────────
BROKEN=false
