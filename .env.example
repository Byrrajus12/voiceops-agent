# ── Dynatrace ──────────────────────────────────────────────────
DYNATRACE_TENANT=wkf10640.apps.dynatrace.com
DYNATRACE_PLATFORM_TOKEN=your_dynatrace_token_here

# ── GitHub ─────────────────────────────────────────────────────
GITHUB_PAT=your_github_pat_here
GITHUB_REPO=Byrrajus12/voiceops-agent

# ── Google / Gemini ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GCP_PROJECT=sreagnt
# Optional: override the Gemini model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ── Services ───────────────────────────────────────────────────
APPROVAL_SERVER_URL=http://localhost:9000

# ── Target Service ─────────────────────────────────────────────
# Set to "true" to activate the 80% failure rate
BROKEN=false
FAILURE_RATE=0.8
